# Connection string do Supabase: Project Settings > Database > Connection string (URI).
# Use a porta 6543 (Connection pooling / pgbouncer) se a Turbocloud não permitir muitas
# conexões simultâneas; a porta 5432 (Direct connection) também funciona.
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# String aleatória longa, só usada pra assinar os tokens de login. Gere uma com:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# Hash da senha do gerente (não é a senha em texto puro). Gere com:
# npm run hash-senha -- "sua-senha-aqui"
GERENTE_SENHA_HASH=

PORT=3001
